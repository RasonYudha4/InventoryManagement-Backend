@page "/warehouses/create"
@using InventoryManagement.UI.Models.Requests
@using System.ComponentModel.DataAnnotations
@attribute [Authorize(Roles = "Admin")]
@inject IWarehouseService WarehouseService
@inject NavigationManager Nav

<PageTitle>New Warehouse — Inventory</PageTitle>

<div class="page-header">
    <div class="page-header-left">
        <a href="/warehouses" class="btn-back"><span class="bi bi-arrow-left"></span> Warehouses</a>
        <div>
            <h1 class="page-title">New Warehouse</h1>
            <p class="page-subtitle">Register a new warehouse facility</p>
        </div>
    </div>
</div>

@if (_error is not null)
{
    <div class="alert-error">
        <span class="bi bi-exclamation-circle-fill"></span> @_error
    </div>
}

<div class="form-card form-card-narrow">
    <EditForm Model="_model" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <div class="form-group">
            <label class="form-label">Code <span class="required">*</span></label>
            <InputText class="form-input" @bind-Value="_model.Code" placeholder="e.g. WH-NY-01" />
            <ValidationMessage For="() => _model.Code" />
            <span class="form-hint">A short unique identifier for this warehouse.</span>
        </div>

        <div class="form-group">
            <label class="form-label">Name <span class="required">*</span></label>
            <InputText class="form-input" @bind-Value="_model.Name" placeholder="e.g. New York Main Warehouse" />
            <ValidationMessage For="() => _model.Name" />
        </div>

        <div class="form-group">
            <label class="form-label">Address</label>
            <InputTextArea class="form-input form-textarea" @bind-Value="_model.Address" rows="3"
                           placeholder="Full street address (optional)" />
        </div>

        <div class="form-actions">
            <a href="/warehouses" class="btn-secondary">Cancel</a>
            <button type="submit" class="btn-primary" disabled="@_submitting">
                @if (_submitting)
                {
                    <span class="spinner-sm"></span> <span>Creating...</span>
                }
                else
                {
                    <span>Create Warehouse</span>
                }
            </button>
        </div>
    </EditForm>
</div>

@code {
    private CreateWarehouseFormModel _model = new();
    private bool _submitting;
    private string? _error;

    private async Task HandleSubmit()
    {
        _submitting = true;
        _error = null;

        try
        {
            var request = new CreateWarehouseRequest(_model.Code, _model.Name, _model.Address);
            var id = await WarehouseService.CreateWarehouseAsync(request);
            Nav.NavigateTo($"/warehouses/{id}");
        }
        catch (Exception ex)
        {
            _error = $"Failed to create warehouse: {ex.Message}";
            _submitting = false;
        }
    }

    private class CreateWarehouseFormModel
    {
        [Required] public string Code { get; set; } = string.Empty;
        [Required] public string Name { get; set; } = string.Empty;
        public string? Address { get; set; }
    }
}
